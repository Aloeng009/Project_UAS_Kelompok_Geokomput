# 1. GEOMETRIC CENTROID ISOLATION
x_coords, y_coords = [], []
for geom in gdf_utama.geometry:
    if geom and not geom.is_empty:
        c = geom.centroid
        x_coords.append(c.x)
        y_coords.append(c.y)

# Statistical Jittering (Mengatasi Singular Matrix pada kalkulasi Gaussian)
x_coords = np.array(x_coords) + np.random.normal(0, 0.00001, len(x_coords))
y_coords = np.array(y_coords) + np.random.normal(0, 0.00001, len(y_coords))

# 2. KDE PROBABILITY MODELING
bounds = array_bounds(dem_meta['height'], dem_meta['width'], transform)
extent = [bounds[0], bounds[2], bounds[1], bounds[3]]

X, Y = np.mgrid[bounds[0]:bounds[2]:300j, bounds[1]:bounds[3]:300j]
positions = np.vstack([X.ravel(), Y.ravel()])

kernel = gaussian_kde(np.vstack([x_coords, y_coords]))
Z = np.reshape(kernel(positions).T, X.shape)

# 3. HEATMAP VISUALIZATION
